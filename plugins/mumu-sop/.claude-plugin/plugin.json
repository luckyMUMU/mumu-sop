{
  "name": "mumu-sop",
  "version": "2.2.0",
  "description": "SOP (Standard Operating Procedure) Skills for software development workflow. Includes 20 skills covering orchestration, specification, implementation, verification, maintenance, and documentation. Features 6-stage workflow (Define→Plan→Build→Verify→Review→Ship), five-axis code review, and P0-P3 constraint hierarchy. Use when managing development workflows, conducting code reviews, implementing features with design-by-contract principles, bug analysis, refactoring, or creating documentation.",
  "author": {
    "name": "luckyMUMU"
  },
  "repository": "https://github.com/luckyMUMU/mumu-sop",
  "license": "MIT",
  "keywords": [
    "sop",
    "workflow",
    "code-review",
    "development",
    "architecture",
    "tdd",
    "bdd",
    "bug-analysis",
    "refactor",
    "tech-debt",
    "progressive-disclosure"
  ],
  "metadata": {
    "claude_code_compatibility": ">=2.0.0",
    "plugin_api_version": "1.0",
    "categories": [
      {
        "id": "workflow",
        "name": "工作流管理"
      },
      {
        "id": "development",
        "name": "开发辅助"
      }
    ],
    "integrations": [
      {
        "plugin": "mumu-model-router",
        "description": "支持动态模型路由，可为不同SOP阶段配置不同模型",
        "optional": true
      }
    ],
    "language_agnostic": true,
    "skillCategories": {
      "language_agnostic": [
        "sop-orchestrator",
        "sop-sync",
        "sop-progress-supervisor",
        "sop-decision-analyst",
        "sop-requirement-analyst",
        "sop-architecture-designer",
        "sop-implementation-designer",
        "sop-code-explorer",
        "sop-code-implementer",
        "sop-test-implementer",
        "sop-architecture-reviewer",
        "sop-code-reviewer",
        "sop-performance-reviewer",
        "sop-bug-analyst",
        "sop-code-refactorer",
        "sop-tech-debt-manager",
        "sop-dependency-manager",
        "sop-document-writer"
      ],
      "language_specific": {
        "sop-spring-reviewer": {
          "languages": ["Java", "Spring Boot"],
          "frameworks": ["Spring Framework", "Spring Boot", "Spring Cloud"],
          "description": "Specialized code reviewer for Java/Spring ecosystems"
        },
        "sop-browser-testing": {
          "languages": ["JavaScript", "TypeScript"],
          "frameworks": ["React", "Vue", "Angular"],
          "description": "Browser testing with Chrome DevTools MCP for frontend projects"
        }
      }
    },
    "commands": {
      "sop": {
        "path": ".claude/commands/sop.md",
        "description": "启动 SOP 工作流统一入口，自动分析任务复杂度并引导 6 阶段流程",
        "triggers": ["sop", "workflow", "开始工作流", "propose", "提案"]
      },
      "init-spec-tree": {
        "path": "commands/init-spec-tree.md",
        "description": "初始化或更新项目约束树。若已有约束，自动对齐更新：检测代码变更、智能合并、保留手动约束",
        "triggers": ["init-spec", "init-tree", "初始化约束树", "创建spec树", "sync-spec", "同步规范", "align", "对齐约束"]
      },
      "spec": {
        "path": ".claude/commands/spec.md",
        "description": "启动 SOP 规范阶段 (Stage 0: Define)，创建结构化需求文档",
        "triggers": ["spec", "define", "规范", "需求分析"]
      },
      "plan": {
        "path": ".claude/commands/plan.md",
        "description": "启动 SOP 计划阶段 (Stage 1: Plan)，垂直切片任务分解",
        "triggers": ["plan", "计划", "规划", "任务分解"]
      },
      "build": {
        "path": ".claude/commands/build.md",
        "description": "启动 SOP 构建阶段 (Stage 2: Build)，增量实现功能",
        "triggers": ["build", "构建", "实现", "开发"]
      },
      "test": {
        "path": ".claude/commands/test.md",
        "description": "启动 SOP 测试阶段 (Stage 3: Verify)，测试验证",
        "triggers": ["test", "测试", "验证", "运行测试"]
      },
      "review": {
        "path": ".claude/commands/review.md",
        "description": "启动 SOP 审查阶段 (Stage 4: Review)，五轴代码审查",
        "triggers": ["review", "审查", "评审", "code review"]
      },
      "ship": {
        "path": ".claude/commands/ship.md",
        "description": "启动 SOP 交付阶段 (Stage 5: Ship)，准备发布",
        "triggers": ["ship", "交付", "发布", "deploy"]
      }
    },
    "agents": {
      "sop-agent": {
        "path": "agents/sop-agent/AGENT.md",
        "description": "SOP 工作流入口 Agent，负责引导用户按照 6 阶段工作流执行软件开发任务。自动分析任务复杂度，动态调整 spec 树深度。",
        "triggers": ["sop", "workflow", "开始工作流", "propose", "提案"]
      }
    },
    "hooks": {
      "pre-apply": {
        "path": "hooks/pre-apply-hook.sh",
        "description": "Stage 2 实现前验证临时节点完整性",
        "triggers": ["stage-2-start", "pre-implement"],
        "actions": [
          {
            "name": "verify-temp-node",
            "description": "验证临时子节点结构完整性"
          },
          {
            "name": "guardrail-check",
            "description": "执行各层级护栏预检查"
          },
          {
            "name": "complexity-confirmation",
            "description": "确认动态深度分析结果"
          },
          {
            "name": "dependency-subtree-check",
            "description": "检查第三方依赖子树状态"
          }
        ]
      },
      "post-archive": {
        "path": "hooks/post-archive-hook.sh",
        "description": "Stage 5 (Ship) 归档后自动更新约束树",
        "triggers": ["stage-5-complete", "post-archive", "post-ship"],
        "actions": [
          {
            "name": "spec-tree-update",
            "description": "从 P3 向上更新约束树"
          },
          {
            "name": "reference-cleanup",
            "description": "解除临时子节点引用关系"
          },
          {
            "name": "changelog-update",
            "description": "更新 CHANGELOG"
          },
          {
            "name": "constraint-validation",
            "description": "验证约束树完整性"
          }
        ]
      }
    },
    "specStorage": {
      "primary": ".sop/specs/",
      "compatible": [".trae/specs/"]
    },
    "entryPoints": {
      "agent": {
        "sop-agent": "完整的6阶段工作流引导，自动分析复杂度"
      },
      "command": {
        "sop": "统一入口：启动 SOP Agent 引导工作流",
        "init-spec-tree": "初始化约束树，有约束时自动对齐更新",
        "spec": "Stage 0: 定义规范",
        "plan": "Stage 1: 计划任务",
        "build": "Stage 2: 构建实现",
        "test": "Stage 3: 测试验证",
        "review": "Stage 4: 五轴审查",
        "ship": "Stage 5: 发布交付"
      },
      "skill": {
        "count": 20,
        "description": "可直接触发的skills，覆盖完整开发周期"
      }
    },
    "fiveAxisReview": {
      "enabled": true,
      "dimensions": ["correctness", "readability", "architecture", "security", "performance"]
    },
    "verticalSlicing": {
      "enabled": true,
      "description": "任务分解采用垂直切片而非水平分层"
    },
    "modelRequirements": {
      "description": "6阶段工作流推荐的模型能力级别，与mumu-model-router的complexity_routing配合使用",
      "stages": {
        "spec": {
          "stage": 0,
          "name": "Define",
          "description": "需求分析与规范定义",
          "capability": "high",
          "reason": "需要深度理解需求、架构决策、生成结构化规范文档"
        },
        "plan": {
          "stage": 1,
          "name": "Plan",
          "description": "垂直切片任务分解",
          "capability": "high",
          "reason": "需要复杂任务分解、依赖分析、工作量估算"
        },
        "build": {
          "stage": 2,
          "name": "Build",
          "description": "增量代码实现",
          "capability": "medium",
          "reason": "标准代码实现，遵循TDD周期，需要平衡质量与效率"
        },
        "test": {
          "stage": 3,
          "name": "Verify",
          "description": "测试验证与调试",
          "capability": "medium",
          "reason": "测试执行、问题定位、修复验证"
        },
        "review": {
          "stage": 4,
          "name": "Review",
          "description": "五轴代码审查",
          "capability": "high",
          "reason": "需要全面审查：正确性、可读性、架构、安全、性能"
        },
        "ship": {
          "stage": 5,
          "name": "Ship",
          "description": "发布交付与归档",
          "capability": "low",
          "reason": "标准化流程：检查清单、文档更新、约束树归档"
        }
      },
      "skillMapping": {
        "high": [
          "sop-decision-analyst",
          "sop-requirement-analyst",
          "sop-architecture-designer",
          "sop-implementation-designer",
          "sop-architecture-reviewer",
          "sop-performance-reviewer",
          "sop-code-reviewer"
        ],
        "medium": [
          "sop-code-implementer",
          "sop-test-implementer",
          "sop-code-explorer",
          "sop-bug-analyst",
          "sop-code-refactorer"
        ],
        "low": [
          "sop-orchestrator",
          "sop-sync",
          "sop-progress-supervisor",
          "sop-document-writer"
        ]
      }
    }
  }
}